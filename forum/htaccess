# ==========================================================
# DMOZ Q&A — /forum/ dizini için sunucu ayarları
# Bu dosyayı sunucuda /forum/.htaccess olarak yükleyin.
# (Dosya adı NOKTA ile başlar, gizli dosyaları göster ayarını
#  açmanız gerekebilir.)
#
# ÖNEMLİ: Temiz URL'ler (/forum/1/genel/baslik.html) İKİ
# katmanla garanti altına alınmıştır:
#  1) Aşağıdaki RewriteEngine kuralları (mod_rewrite varsa,
#     en hızlı ve görünmez yöntem)
#  2) ErrorDocument 404 satırı (mod_rewrite kapalı olsa BİLE
#     çalışır — 404.html dosyası isteği index.html'e taşır)
# Böylece barındırma sağlayıcınızın ayarlarından bağımsız
# olarak linkler kesinlikle çalışır.
# ==========================================================

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /forum/

  # HTTPS zorunlu kıl
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Gerçek bir dosya veya klasörse dokunma (css, js, resim vb.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # /forum/12/genel/baslik.html gibi tüm temiz URL'leri
  # uygulamanın kendisine (index.html) yönlendir
  RewriteRule ^ index.html [L]
</IfModule>

# ---- Yedek katman: mod_rewrite kapalıysa bile çalışır ----
ErrorDocument 404 /forum/404.html

# ---- Performans: sıkıştırma ----
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml
</IfModule>

# ---- Performans: tarayıcı önbellekleme ----
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpg "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType text/css "access plus 1 week"
  ExpiresByType application/javascript "access plus 1 week"
</IfModule>

# ---- Güvenlik başlıkları ----
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
